<Window x:Class="SchoolApp.View.PerformanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Успеваемость" Height="550" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#821409" CornerRadius="8" 
                Padding="12" Margin="0,0,0,15">
            <TextBlock Text="Успеваемость" FontSize="20" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Выбор ученика -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" 
                Padding="15" Margin="0,0,0,10"
                BorderBrush="#CBD5E0" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Ученик:" VerticalAlignment="Center" 
                           Margin="0,0,10,0" FontSize="14" FontWeight="SemiBold"/>
                <ComboBox x:Name="StudentComboBox" Width="300" Height="30"
                          SelectionChanged="StudentComboBox_SelectionChanged"
                          FontSize="13"/>
                <Button Content="Сохранить" Margin="20,0,0,0" 
                        Width="120" Height="32" FontSize="14"
                        Foreground="White" FontWeight="SemiBold"
                        Cursor="Hand" Click="SaveButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#38A169" CornerRadius="10"
                                    BorderThickness="0" Padding="6">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <!-- Таблица оценок -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" 
                Padding="10" Margin="0,0,0,10"
                BorderBrush="#CBD5E0" BorderThickness="1">
            <DataGrid x:Name="GradesGrid" 
                      AutoGenerateColumns="False"
                      Background="White"
                      BorderThickness="0"
                      RowHeight="30"
                      ColumnHeaderHeight="35">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Предмет" Binding="{Binding Subject}" 
                                        IsReadOnly="True" Width="*"/>
                    <DataGridTextColumn Header="Оценка" Binding="{Binding Grade}" 
                                        Width="120"/>
                </DataGrid.Columns>
                
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#2C5282"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FEEBC8"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FBD38D"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
            </DataGrid>
        </Border>

        <!-- Кнопки -->
        <Border Grid.Row="3" Background="White" CornerRadius="8" 
                Padding="10" BorderBrush="#CBD5E0" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                
                <Button Content="Удалить успеваемость" Margin="5" Width="170" Height="35"
                        Foreground="White" FontWeight="SemiBold" FontSize="14"
                        Cursor="Hand" Click="DeleteButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#E53E3E" CornerRadius="10"
                                    BorderThickness="0" Padding="8">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="Обновить" Margin="5" Width="120" Height="35"
                        Foreground="White" FontWeight="SemiBold" FontSize="14"
                        Cursor="Hand" Click="RefreshButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#718096" CornerRadius="8"
                                    BorderThickness="0" Padding="10" Cursor="">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>