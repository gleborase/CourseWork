<Window x:Class="SchoolApp.View.PerformanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Успеваемость" Height="500" Width="650"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- Выбор ученика -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Ученик:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox x:Name="StudentComboBox" Width="250" 
                      SelectionChanged="StudentComboBox_SelectionChanged"/>
            <Button Content="Сохранить" Width="100" Height="30" 
                    Margin="20,0,0,0" Click="SaveButton_Click"/>
        </StackPanel>

        <!-- Таблица оценок -->
        <DataGrid x:Name="GradesGrid" Grid.Row="1" 
                  AutoGenerateColumns="False"
                  Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Предмет" Binding="{Binding Subject}" 
                                    IsReadOnly="True" Width="*"/>
                <DataGridTextColumn Header="Оценка" Binding="{Binding Grade}" 
                                    Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center">
            <Button Content="Удалить успеваемость" Width="150" Height="35" 
                    Margin="5" Click="DeleteButton_Click"/>
            <Button Content="Обновить" Width="100" Height="35" 
                    Margin="5" Click="RefreshButton_Click"/>
        </StackPanel>
    </Grid>
</Window>