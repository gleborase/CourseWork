<Window x:Class="SchoolApp.View.AnalyticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Аналитика" Height="600" Width="750"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#821409" CornerRadius="8" 
                Padding="12" Margin="0,0,0,15">
            <TextBlock Text="Аналитика" FontSize="20" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Выбор запроса -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" 
                Padding="15" Margin="0,0,0,10"
                BorderBrush="#CBD5E0" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Запрос:" VerticalAlignment="Center" 
                           Margin="0,0,10,0" FontSize="14" FontWeight="SemiBold"/>
                <ComboBox x:Name="QueryComboBox" Width="400" Height="30"
                          SelectionChanged="QueryComboBox_SelectionChanged"
                          FontSize="13">
                    <ComboBoxItem Content="Успеваемость по заданному предмету"/>
                    <ComboBoxItem Content="Количество неуспевающих учеников по всем классам"/>
                    <ComboBoxItem Content="У какого учителя самая низкая успеваемость"/>
                    <ComboBoxItem Content="Средняя оценка по всем предметам в каждом классе"/>
                    <ComboBoxItem Content="Класс с самой высокой успеваемостью"/>
                    <ComboBoxItem Content="Класс с самой низкой успеваемостью"/>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Поле ввода предмета и кнопка -->
        <Border Grid.Row="2" x:Name="SubjectPanel" Background="White" 
                CornerRadius="8" Padding="15" Margin="0,0,0,10"
                BorderBrush="#CBD5E0" BorderThickness="1"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Предмет:" VerticalAlignment="Center" 
                           Margin="0,0,15,0" FontSize="14" FontWeight="SemiBold"/>
                <TextBox Grid.Column="1" x:Name="SubjectTextBox" Height="30" FontSize="13"
                         VerticalAlignment="Center"/>
                <Button Grid.Column="2" Content="Показать" Margin="15,0,0,0" 
                        Width="130" Height="32" FontSize="14"
                        Foreground="White" FontWeight="SemiBold"
                        Cursor="Hand" Click="ShowButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#821409" CornerRadius="10"
                                    BorderThickness="0" Padding="6" Cursor="">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Результаты -->
        <Border Grid.Row="3" Background="White" CornerRadius="8" 
                Padding="10" BorderBrush="#CBD5E0" BorderThickness="1">
            <ScrollViewer>
                <StackPanel>
                    <TextBlock x:Name="ResultText" FontSize="15" 
                               TextWrapping="Wrap"
                               HorizontalAlignment="Left" Margin="10"
                               FontWeight="SemiBold"
                               Visibility="Collapsed"/>
                    <DataGrid x:Name="ResultGrid" AutoGenerateColumns="True" 
                              IsReadOnly="True"
                              Background="White"
                              BorderThickness="0"
                              RowHeight="30"
                              ColumnHeaderHeight="35"
                              MinHeight="200"
                              Visibility="Collapsed">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#2C5282"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="White"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FEEBC8"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#FBD38D"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                    </DataGrid>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>