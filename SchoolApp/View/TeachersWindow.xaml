<Window x:Class="SchoolApp.View.TeachersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учителя" Height="500" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#FF821409" CornerRadius="8" 
                Padding="12" Margin="0,0,0,15">
            <TextBlock Text="Учителя" FontSize="26" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Таблица -->
        <DataGrid x:Name="TeachersGrid" Grid.Row="1" 
          AutoGenerateColumns="False" 
          IsReadOnly="True"
          SelectionMode="Single"
          Background="White"
          BorderBrush="#CBD5E0"
          BorderThickness="1"
          RowHeight="30"
          ColumnHeaderHeight="35"
          Margin="0,0,0,15">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Предмет" Binding="{Binding Subject}" Width="150"/>
                <DataGridTextColumn Header="№ Кабинета" Binding="{Binding ClassroomNumber}" Width="100"/>
            </DataGrid.Columns>

            <!-- Стили остаются те же -->
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#2C5282"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="White"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#EBF4FF"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#BEE3F8"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>
        </DataGrid>
        <!-- Кнопки -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" 
                Padding="10" BorderBrush="#CBD5E0" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <Button Content="Добавить" Margin="5" Width="120" Height="35"
                        Foreground="White" FontWeight="SemiBold" FontSize="13"
                        Cursor="Hand" Click="AddButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#38A169" CornerRadius="6"
                                    BorderThickness="0" Padding="8">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="Редактировать" Margin="5" Width="130" Height="35"
                        Foreground="White" FontWeight="SemiBold" FontSize="13"
                        Cursor="Hand" Click="EditButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#3182CE" CornerRadius="6"
                                    BorderThickness="0" Padding="8">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="Удалить" Margin="5" Width="120" Height="35"
                        Foreground="White" FontWeight="SemiBold" FontSize="13"
                        Cursor="Hand" Click="DeleteButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#E53E3E" CornerRadius="6"
                                    BorderThickness="0" Padding="8">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="Обновить" Margin="5" Width="120" Height="35"
                        Foreground="White" FontWeight="SemiBold" FontSize="13"
                        Cursor="Hand" Click="RefreshButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#718096" CornerRadius="6"
                                    BorderThickness="0" Padding="8" Cursor="">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>