<Window x:Class="SchoolApp.View.TeachersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учителя" Height="450" Width="650"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- Таблица учителей -->
        <DataGrid x:Name="TeachersGrid" Grid.Row="0" 
                  AutoGenerateColumns="True" 
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Margin="0,0,0,10"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" 
                    HorizontalAlignment="Center">
            <Button Content="Добавить" Width="100" Height="35"
                    Margin="5" Click="AddButton_Click"/>
            <Button Content="Редактировать" Width="100" Height="35" 
                    Margin="5" Click="EditButton_Click"/>
            <Button Content="Удалить" Width="100" Height="35" 
                    Margin="5" Click="DeleteButton_Click"/>
            <Button Content="Обновить" Width="100" Height="35" 
                    Margin="5" Click="RefreshButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
